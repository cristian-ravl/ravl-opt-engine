// ADX database schema — creates all tables, mappings, and materialized views.
// Run this KQL script against the OptimizationEngine database to bootstrap.
// In the ADX web UI, Run executes only the current statement unless the full script is selected.
// To apply the whole file in one request, wrap it with `.execute database script <|` and paste the file contents below it.

// ============================================================================
// Resource collection tables
// ============================================================================

.create-merge table VirtualMachines (
    Timestamp: datetime,
    Cloud: string,
    TenantId: string,
    SubscriptionId: string,
    ResourceGroup: string,
    Zones: dynamic,
    Location: string,
    VMName: string,
    DeploymentModel: string,
    InstanceId: string,
    VMSize: string,
    CoresCount: int,
    MemoryMB: int,
    OSType: string,
    LicenseType: string,
    DataDiskCount: int,
    NicCount: int,
    UsesManagedDisks: bool,
    AvailabilitySetId: string,
    BootDiagnosticsEnabled: bool,
    BootDiagnosticsStorageAccount: string,
    PowerState: string,
    ImagePublisher: string,
    ImageOffer: string,
    ImageSku: string,
    ImageVersion: string,
    ImageExactVersion: string,
    OsName: string,
    OsVersion: string,
    StatusDate: datetime,
    Tags: dynamic
    )

.create-merge table ManagedDisks (
    Timestamp: datetime,
    Cloud: string,
    TenantId: string,
    SubscriptionId: string,
    ResourceGroup: string,
    DiskName: string,
    InstanceId: string,
    Location: string,
    OwnerVMId: string,
    DeploymentModel: string,
    DiskType: string,
    TimeCreated: datetime,
    DiskIOPS: long,
    DiskThroughput: long,
    DiskTier: string,
    DiskState: string,
    EncryptionType: string,
    Zones: dynamic,
    Caching: string,
    DiskSizeGB: int,
    SKU: string,
    StatusDate: datetime,
    Tags: dynamic
    )

.create-merge table AppServicePlans (
    Timestamp: datetime,
    Cloud: string,
    TenantId: string,
    SubscriptionId: string,
    ResourceGroup: string,
    ZoneRedundant: bool,
    Location: string,
    AppServicePlanName: string,
    InstanceId: string,
    Kind: string,
    SkuName: string,
    SkuTier: string,
    SkuCapacity: int,
    SkuFamily: string,
    SkuSize: string,
    ComputeMode: string,
    NumberOfWorkers: int,
    CurrentNumberOfWorkers: int,
    MaximumNumberOfWorkers: int,
    NumberOfSites: int,
    PlanName: string,
    Tags: dynamic,
    StatusDate: datetime
    )

.create-merge table LoadBalancers (
    Timestamp: datetime,
    Cloud: string,
    TenantId: string,
    SubscriptionId: string,
    ResourceGroup: string,
    InstanceName: string,
    InstanceId: string,
    SkuName: string,
    SkuTier: string,
    Location: string,
    LbType: string,
    LbRulesCount: int,
    InboundNatRulesCount: int,
    OutboundRulesCount: int,
    FrontendIPsCount: int,
    BackendIPCount: int,
    BackendAddressesCount: int,
    InboundNatPoolsCount: int,
    BackendPoolsCount: int,
    ProbesCount: int,
    StatusDate: datetime,
    Tags: dynamic
    )

.create-merge table NetworkInterfaces (
    Timestamp: datetime,
    Cloud: string,
    TenantId: string,
    SubscriptionId: string,
    ResourceGroup: string,
    Location: string,
    Name: string,
    InstanceId: string,
    IsPrimary: bool,
    EnableAcceleratedNetworking: bool,
    EnableIPForwarding: bool,
    TapConfigurationsCount: int,
    HostedWorkloadsCount: int,
    InternalDomainNameSuffix: string,
    OwnerVMId: string,
    OwnerPEId: string,
    MacAddress: string,
    NicType: string,
    NicNSGId: string,
    PrivateIPAddressVersion: string,
    PrivateIPAllocationMethod: string,
    IsIPConfigPrimary: bool,
    PrivateIPAddress: string,
    PublicIPId: string,
    IPConfigName: string,
    SubnetId: string,
    Tags: dynamic,
    StatusDate: datetime
    )

.create-merge table NetworkSecurityGroups (
    Timestamp: datetime,
    Cloud: string,
    TenantId: string,
    SubscriptionId: string,
    ResourceGroup: string,
    Location: string,
    NSGName: string,
    InstanceId: string,
    NicCount: int,
    SubnetCount: int,
    RuleName: string,
    RuleProtocol: string,
    RuleDirection: string,
    RulePriority: int,
    RuleAccess: string,
    RuleDestinationAddresses: string,
    RuleSourceAddresses: string,
    RuleDestinationPorts: string,
    RuleSourcePorts: string,
    Tags: dynamic,
    StatusDate: datetime
    )

.create-merge table PublicIPs (
    Timestamp: datetime,
    Cloud: string,
    TenantId: string,
    SubscriptionId: string,
    ResourceGroup: string,
    Location: string,
    Name: string,
    InstanceId: string,
    Model: string,
    SkuName: string,
    SkuTier: string,
    AllocationMethod: string,
    AddressVersion: string,
    AssociatedResourceId: string,
    PublicIpPrefixId: string,
    IPAddress: string,
    FQDN: string,
    Zones: dynamic,
    Tags: dynamic,
    StatusDate: datetime
    )

.create-merge table ResourceContainers (
    Timestamp: datetime,
    Cloud: string,
    TenantId: string,
    SubscriptionId: string,
    Location: string,
    ContainerType: string,
    ContainerName: string,
    InstanceId: string,
    ResourceCount: int,
    ManagedBy: string,
    ContainerProperties: dynamic,
    Tags: dynamic,
    StatusDate: datetime
    )

.create-merge table SqlDatabases (
    Timestamp: datetime,
    Cloud: string,
    TenantId: string,
    SubscriptionId: string,
    ResourceGroup: string,
    ZoneRedundant: bool,
    Location: string,
    DBName: string,
    InstanceId: string,
    SkuName: string,
    SkuTier: string,
    SkuCapacity: int,
    ServiceObjectiveName: string,
    StorageAccountType: string,
    LicenseType: string,
    MaxSizeBytes: long,
    MaxLogSizeBytes: long,
    Tags: dynamic,
    StatusDate: datetime
    )

.create-merge table UnmanagedDisks (
    Timestamp: datetime,
    Cloud: string,
    TenantId: string,
    SubscriptionId: string,
    ResourceGroup: string,
    DiskName: string,
    InstanceId: string,
    OwnerVMId: string,
    Location: string,
    DeploymentModel: string,
    DiskType: string,
    Caching: string,
    DiskSizeGB: int,
    StatusDate: datetime,
    Tags: dynamic
    )

.create-merge table VirtualMachineScaleSets (
    Timestamp: datetime,
    Cloud: string,
    TenantId: string,
    SubscriptionId: string,
    ResourceGroup: string,
    Zones: dynamic,
    Location: string,
    VMSSName: string,
    ComputerNamePrefix: string,
    InstanceId: string,
    VMSSSize: string,
    CoresCount: int,
    MemoryMB: int,
    OSType: string,
    DataDiskCount: int,
    NicCount: int,
    Capacity: int,
    Priority: string,
    OSDiskSize: int,
    OSDiskCaching: string,
    OSDiskSKU: string,
    SinglePlacementGroup: bool,
    UpgradePolicy: string,
    OverProvision: bool,
    PlatformFaultDomainCount: int,
    ZoneBalance: bool,
    UsesManagedDisks: bool,
    ImagePublisher: string,
    ImageOffer: string,
    ImageSku: string,
    ImageVersion: string,
    ImageExactVersion: string,
    StatusDate: datetime,
    Tags: dynamic
    )

.create-merge table VirtualNetworks (
    Timestamp: datetime,
    Cloud: string,
    TenantId: string,
    SubscriptionId: string,
    ResourceGroup: string,
    Location: string,
    VNetName: string,
    InstanceId: string,
    Model: string,
    VNetPrefixes: dynamic,
    DNSServers: dynamic,
    PeeringsCount: int,
    EnableDdosProtection: bool,
    SubnetName: string,
    SubnetPrefix: string,
    SubnetDelegationsCount: int,
    SubnetTotalPrefixIPs: int,
    SubnetUsedIPs: int,
    SubnetNSGId: string,
    Tags: dynamic,
    StatusDate: datetime
    )

.create-merge table ApplicationGateways (
    Timestamp: datetime,
    Cloud: string,
    TenantId: string,
    SubscriptionId: string,
    ResourceGroup: string,
    InstanceName: string,
    InstanceId: string,
    SkuName: string,
    SkuTier: string,
    SkuCapacity: int,
    Location: string,
    Zones: dynamic,
    EnableHttp2: bool,
    GatewayIPsCount: int,
    FrontendIPsCount: int,
    FrontendPortsCount: int,
    BackendIPCount: int,
    BackendAddressesCount: int,
    HttpSettingsCount: int,
    HttpListenersCount: int,
    BackendPoolsCount: int,
    ProbesCount: int,
    UrlPathMapsCount: int,
    RequestRoutingRulesCount: int,
    RewriteRulesCount: int,
    RedirectConfsCount: int,
    StatusDate: datetime,
    Tags: dynamic
    )

.create-merge table AvailabilitySets (
    Timestamp: datetime,
    Cloud: string,
    TenantId: string,
    SubscriptionId: string,
    ResourceGroup: string,
    InstanceName: string,
    InstanceId: string,
    SkuName: string,
    Location: string,
    FaultDomains: int,
    UpdateDomains: int,
    VmCount: int,
    StatusDate: datetime,
    Tags: dynamic,
    Zones: dynamic
    )

.create-merge table AdvisorRecommendations (
    Timestamp: datetime,
    Cloud: string,
    TenantId: string,
    SubscriptionId: string,
    ResourceGroup: string,
    InstanceId: string,
    InstanceName: string,
    Category: string,
    Impact: string,
    ImpactedArea: string,
    RecommendationSubTypeId: string,
    RecommendationDescription: string,
    RecommendationAction: string,
    AdditionalInfo: dynamic,
    DetailsUrl: string,
    StatusDate: datetime
    )

.create-merge table PriceSheetData (
    Timestamp: datetime,
    Cloud: string,
    BillingAccountId: string,
    BillingProfileId: string,
    BillingPeriod: string,
    MeterId: string,
    MeterName: string,
    MeterCategory: string,
    MeterSubCategory: string,
    MeterRegion: string,
    UnitOfMeasure: string,
    PartNumber: string,
    UnitPrice: real,
    CurrencyCode: string,
    IncludedQuantity: real,
    OfferId: string,
    Term: string,
    PriceType: string
    )

.create-merge table ReservationsPriceData (
    Timestamp: datetime,
    Cloud: string,
    CurrencyCode: string,
    ServiceName: string,
    ArmSkuName: string,
    ArmRegionName: string,
    ReservationTerm: string,
    MeterName: string,
    MeterId: string,
    SkuName: string,
    ProductName: string,
    UnitOfMeasure: string,
    UnitPrice: real,
    RetailPrice: real,
    Type: string,
    PriceType: string
    )

.create-merge table ReservationsUsage (
    Timestamp: datetime,
    Cloud: string,
    TenantId: string,
    Scope: string,
    ReservationResourceId: string,
    ReservationOrderId: string,
    ReservationId: string,
    DisplayName: string,
    SkuName: string,
    Location: string,
    ResourceType: string,
    AppliedScopeType: string,
    Term: string,
    ProvisioningState: string,
    RenewState: string,
    PurchaseDate: datetime,
    ExpiryDate: datetime,
    Archived: bool,
    ReservedHours: real,
    UsedHours: real,
    UsageDate: datetime,
    MinUtilPercentage: real,
    AvgUtilPercentage: real,
    MaxUtilPercentage: real,
    PurchasedQuantity: real,
    RemainingQuantity: real,
    TotalReservedQuantity: real,
    UsedQuantity: real,
    UtilizedPercentage: real,
    UtilTrend: string,
    Util1Days: real,
    Util7Days: real,
    Util30Days: real
    )

.create-merge table SavingsPlansUsage (
    Timestamp: datetime,
    Cloud: string,
    TenantId: string,
    Scope: string,
    SavingsPlanResourceId: string,
    SavingsPlanOrderId: string,
    SavingsPlanId: string,
    DisplayName: string,
    SkuName: string,
    Term: string,
    ProvisioningState: string,
    AppliedScopeType: string,
    RenewState: string,
    PurchaseDate: datetime,
    BenefitStart: datetime,
    ExpiryDate: datetime,
    EffectiveDate: datetime,
    BillingScopeId: string,
    BillingAccountId: string,
    BillingProfileId: string,
    BillingPlan: string,
    CommitmentGrain: string,
    CommitmentCurrencyCode: string,
    CommitmentAmount: real,
    UtilTrend: string,
    Util1Days: real,
    Util7Days: real,
    Util30Days: real
    )

.create-merge table AADObjects (
    Timestamp: datetime,
    Cloud: string,
    TenantId: string,
    ObjectId: string,
    AppId: string,
    DisplayName: string,
    CredentialType: string,
    CredentialId: string,
    StartDate: datetime,
    EndDate: datetime,
    StatusDate: datetime
    )

.create-merge table RBACAssignments (
    Timestamp: datetime,
    Cloud: string,
    SubscriptionId: string,
    RoleAssignmentId: string,
    Scope: string,
    RoleDefinitionId: string,
    PrincipalId: string,
    PrincipalType: string,
    Description: string,
    Condition: string,
    ConditionVersion: string,
    CreatedOn: datetime,
    UpdatedOn: datetime,
    StatusDate: datetime
    )

.create-merge table PolicyCompliance (
    Timestamp: datetime,
    Cloud: string,
    TenantId: string,
    SubscriptionId: string,
    ResourceGroup: string,
    ResourceId: string,
    ResourceType: string,
    ResourceLocation: string,
    PolicyAssignmentId: string,
    PolicyDefinitionId: string,
    PolicySetDefinitionId: string,
    ComplianceState: string,
    Details: dynamic,
    StatusDate: datetime
    )

// ============================================================================
// Recommendation and suppression tables
// ============================================================================

.create-merge table Recommendations (
    RecommendationId: guid,
    GeneratedDate: datetime,
    RecommenderId: string,
    RecommenderName: string,
    Cloud: string,
    Category: string,
    ImpactedArea: string,
    Impact: string,
    RecommendationType: string,
    RecommendationSubType: string,
    RecommendationSubTypeId: guid,
    RecommendationDescription: string,
    RecommendationAction: string,
    InstanceId: string,
    InstanceName: string,
    AdditionalInfo: dynamic,
    ResourceGroup: string,
    SubscriptionId: string,
    SubscriptionName: string,
    TenantId: string,
    FitScore: real,
    Tags: dynamic,
    DetailsUrl: string
    )

.create-merge table Suppressions (
    FilterId: guid,
    RecommendationSubTypeId: guid,
    FilterType: string,
    InstanceId: string,
    FilterStartDate: datetime,
    FilterEndDate: datetime,
    Author: string,
    Notes: string,
    IsEnabled: bool
    )

// ============================================================================
// Remediation log
// ============================================================================

.create-merge table RemediationLog (
    RemediationId: guid,
    RecommendationId: guid,
    Cloud: string,
    InstanceId: string,
    Action: string,
    Status: string,
    ExecutedAt: datetime,
    ExecutedBy: string,
    ErrorMessage: string
    )

// ============================================================================
// Metrics tables (from Azure Monitor / CloudWatch / GCP Monitoring)
// ============================================================================

.create-merge table PerformanceMetrics (
    Timestamp: datetime,
    Cloud: string,
    SubscriptionId: string,
    InstanceId: string,
    MetricName: string,
    AggregationType: string,
    AggregationOfType: string,
    Value: real,
    Unit: string,
    TimeGrain: string,
    TimeSpan: string
    )

// ============================================================================
// Cost / consumption data
// ============================================================================

.create-merge table CostData (
    Timestamp: datetime,
    Cloud: string,
    SubscriptionId: string,
    ResourceGroup: string,
    InstanceId: string,
    MeterCategory: string,
    MeterSubCategory: string,
    MeterName: string,
    UnitOfMeasure: string,
    Quantity: real,
    Cost: real,
    Currency: string,
    BillingPeriod: string,
    Tags: dynamic,
    UsageDate: datetime
    )

// ============================================================================
// Ingestion control (tracks last-processed markers)
// ============================================================================

.create-merge table IngestionControl (
    SourceId: string,
    LastProcessedDateTime: datetime,
    LastProcessedMarker: string,
    TargetTableSuffix: string,
    CollectedType: string
    )

// ============================================================================
// JSON ingestion mappings
// ============================================================================

.create-or-alter table VirtualMachines ingestion json mapping 'VirtualMachines_mapping'
    '[{"column":"Timestamp","path":"$.timestamp"},{"column":"Cloud","path":"$.cloud"},{"column":"TenantId","path":"$.tenantId"},{"column":"SubscriptionId","path":"$.subscriptionId"},{"column":"ResourceGroup","path":"$.resourceGroup"},{"column":"Zones","path":"$.zones"},{"column":"Location","path":"$.location"},{"column":"VMName","path":"$.vmName"},{"column":"DeploymentModel","path":"$.deploymentModel"},{"column":"InstanceId","path":"$.instanceId"},{"column":"VMSize","path":"$.vmSize"},{"column":"CoresCount","path":"$.coresCount"},{"column":"MemoryMB","path":"$.memoryMB"},{"column":"OSType","path":"$.osType"},{"column":"LicenseType","path":"$.licenseType"},{"column":"DataDiskCount","path":"$.dataDiskCount"},{"column":"NicCount","path":"$.nicCount"},{"column":"UsesManagedDisks","path":"$.usesManagedDisks"},{"column":"AvailabilitySetId","path":"$.availabilitySetId"},{"column":"BootDiagnosticsEnabled","path":"$.bootDiagnosticsEnabled"},{"column":"BootDiagnosticsStorageAccount","path":"$.bootDiagnosticsStorageAccount"},{"column":"PowerState","path":"$.powerState"},{"column":"ImagePublisher","path":"$.imagePublisher"},{"column":"ImageOffer","path":"$.imageOffer"},{"column":"ImageSku","path":"$.imageSku"},{"column":"ImageVersion","path":"$.imageVersion"},{"column":"ImageExactVersion","path":"$.imageExactVersion"},{"column":"OsName","path":"$.osName"},{"column":"OsVersion","path":"$.osVersion"},{"column":"StatusDate","path":"$.statusDate"},{"column":"Tags","path":"$.tags"}]'

.create-or-alter table ManagedDisks ingestion json mapping 'ManagedDisks_mapping'
    '[{"column":"Timestamp","path":"$.timestamp"},{"column":"Cloud","path":"$.cloud"},{"column":"TenantId","path":"$.tenantId"},{"column":"SubscriptionId","path":"$.subscriptionId"},{"column":"ResourceGroup","path":"$.resourceGroup"},{"column":"DiskName","path":"$.diskName"},{"column":"InstanceId","path":"$.instanceId"},{"column":"Location","path":"$.location"},{"column":"OwnerVMId","path":"$.ownerVMId"},{"column":"DeploymentModel","path":"$.deploymentModel"},{"column":"DiskType","path":"$.diskType"},{"column":"TimeCreated","path":"$.timeCreated"},{"column":"DiskIOPS","path":"$.diskIOPS"},{"column":"DiskThroughput","path":"$.diskThroughput"},{"column":"DiskTier","path":"$.diskTier"},{"column":"DiskState","path":"$.diskState"},{"column":"EncryptionType","path":"$.encryptionType"},{"column":"Zones","path":"$.zones"},{"column":"Caching","path":"$.caching"},{"column":"DiskSizeGB","path":"$.diskSizeGB"},{"column":"SKU","path":"$.sku"},{"column":"StatusDate","path":"$.statusDate"},{"column":"Tags","path":"$.tags"}]'

.create-or-alter table AppServicePlans ingestion json mapping 'AppServicePlans_mapping'
    '[{"column":"Timestamp","path":"$.timestamp"},{"column":"Cloud","path":"$.cloud"},{"column":"TenantId","path":"$.tenantId"},{"column":"SubscriptionId","path":"$.subscriptionId"},{"column":"ResourceGroup","path":"$.resourceGroup"},{"column":"ZoneRedundant","path":"$.zoneRedundant"},{"column":"Location","path":"$.location"},{"column":"AppServicePlanName","path":"$.appServicePlanName"},{"column":"InstanceId","path":"$.instanceId"},{"column":"Kind","path":"$.kind"},{"column":"SkuName","path":"$.skuName"},{"column":"SkuTier","path":"$.skuTier"},{"column":"SkuCapacity","path":"$.skuCapacity"},{"column":"SkuFamily","path":"$.skuFamily"},{"column":"SkuSize","path":"$.skuSize"},{"column":"ComputeMode","path":"$.computeMode"},{"column":"NumberOfWorkers","path":"$.numberOfWorkers"},{"column":"CurrentNumberOfWorkers","path":"$.currentNumberOfWorkers"},{"column":"MaximumNumberOfWorkers","path":"$.maximumNumberOfWorkers"},{"column":"NumberOfSites","path":"$.numberOfSites"},{"column":"PlanName","path":"$.planName"},{"column":"Tags","path":"$.tags"},{"column":"StatusDate","path":"$.statusDate"}]'

.create-or-alter table LoadBalancers ingestion json mapping 'LoadBalancers_mapping'
    '[{"column":"Timestamp","path":"$.timestamp"},{"column":"Cloud","path":"$.cloud"},{"column":"TenantId","path":"$.tenantId"},{"column":"SubscriptionId","path":"$.subscriptionId"},{"column":"ResourceGroup","path":"$.resourceGroup"},{"column":"InstanceName","path":"$.instanceName"},{"column":"InstanceId","path":"$.instanceId"},{"column":"SkuName","path":"$.skuName"},{"column":"SkuTier","path":"$.skuTier"},{"column":"Location","path":"$.location"},{"column":"LbType","path":"$.lbType"},{"column":"LbRulesCount","path":"$.lbRulesCount"},{"column":"InboundNatRulesCount","path":"$.inboundNatRulesCount"},{"column":"OutboundRulesCount","path":"$.outboundRulesCount"},{"column":"FrontendIPsCount","path":"$.frontendIPsCount"},{"column":"BackendIPCount","path":"$.backendIPCount"},{"column":"BackendAddressesCount","path":"$.backendAddressesCount"},{"column":"InboundNatPoolsCount","path":"$.inboundNatPoolsCount"},{"column":"BackendPoolsCount","path":"$.backendPoolsCount"},{"column":"ProbesCount","path":"$.probesCount"},{"column":"StatusDate","path":"$.statusDate"},{"column":"Tags","path":"$.tags"}]'

.create-or-alter table NetworkInterfaces ingestion json mapping 'NetworkInterfaces_mapping'
    '[{"column":"Timestamp","path":"$.timestamp"},{"column":"Cloud","path":"$.cloud"},{"column":"TenantId","path":"$.tenantId"},{"column":"SubscriptionId","path":"$.subscriptionId"},{"column":"ResourceGroup","path":"$.resourceGroup"},{"column":"Location","path":"$.location"},{"column":"Name","path":"$.name"},{"column":"InstanceId","path":"$.instanceId"},{"column":"IsPrimary","path":"$.isPrimary"},{"column":"EnableAcceleratedNetworking","path":"$.enableAcceleratedNetworking"},{"column":"EnableIPForwarding","path":"$.enableIPForwarding"},{"column":"TapConfigurationsCount","path":"$.tapConfigurationsCount"},{"column":"HostedWorkloadsCount","path":"$.hostedWorkloadsCount"},{"column":"InternalDomainNameSuffix","path":"$.internalDomainNameSuffix"},{"column":"OwnerVMId","path":"$.ownerVMId"},{"column":"OwnerPEId","path":"$.ownerPEId"},{"column":"MacAddress","path":"$.macAddress"},{"column":"NicType","path":"$.nicType"},{"column":"NicNSGId","path":"$.nicNSGId"},{"column":"PrivateIPAddressVersion","path":"$.privateIPAddressVersion"},{"column":"PrivateIPAllocationMethod","path":"$.privateIPAllocationMethod"},{"column":"IsIPConfigPrimary","path":"$.isIPConfigPrimary"},{"column":"PrivateIPAddress","path":"$.privateIPAddress"},{"column":"PublicIPId","path":"$.publicIPId"},{"column":"IPConfigName","path":"$.ipConfigName"},{"column":"SubnetId","path":"$.subnetId"},{"column":"Tags","path":"$.tags"},{"column":"StatusDate","path":"$.statusDate"}]'

.create-or-alter table NetworkSecurityGroups ingestion json mapping 'NetworkSecurityGroups_mapping'
    '[{"column":"Timestamp","path":"$.timestamp"},{"column":"Cloud","path":"$.cloud"},{"column":"TenantId","path":"$.tenantId"},{"column":"SubscriptionId","path":"$.subscriptionId"},{"column":"ResourceGroup","path":"$.resourceGroup"},{"column":"Location","path":"$.location"},{"column":"NSGName","path":"$.nsgName"},{"column":"InstanceId","path":"$.instanceId"},{"column":"NicCount","path":"$.nicCount"},{"column":"SubnetCount","path":"$.subnetCount"},{"column":"RuleName","path":"$.ruleName"},{"column":"RuleProtocol","path":"$.ruleProtocol"},{"column":"RuleDirection","path":"$.ruleDirection"},{"column":"RulePriority","path":"$.rulePriority"},{"column":"RuleAccess","path":"$.ruleAccess"},{"column":"RuleDestinationAddresses","path":"$.ruleDestinationAddresses"},{"column":"RuleSourceAddresses","path":"$.ruleSourceAddresses"},{"column":"RuleDestinationPorts","path":"$.ruleDestinationPorts"},{"column":"RuleSourcePorts","path":"$.ruleSourcePorts"},{"column":"Tags","path":"$.tags"},{"column":"StatusDate","path":"$.statusDate"}]'

.create-or-alter table PublicIPs ingestion json mapping 'PublicIPs_mapping'
    '[{"column":"Timestamp","path":"$.timestamp"},{"column":"Cloud","path":"$.cloud"},{"column":"TenantId","path":"$.tenantId"},{"column":"SubscriptionId","path":"$.subscriptionId"},{"column":"ResourceGroup","path":"$.resourceGroup"},{"column":"Location","path":"$.location"},{"column":"Name","path":"$.name"},{"column":"InstanceId","path":"$.instanceId"},{"column":"Model","path":"$.model"},{"column":"SkuName","path":"$.skuName"},{"column":"SkuTier","path":"$.skuTier"},{"column":"AllocationMethod","path":"$.allocationMethod"},{"column":"AddressVersion","path":"$.addressVersion"},{"column":"AssociatedResourceId","path":"$.associatedResourceId"},{"column":"PublicIpPrefixId","path":"$.publicIpPrefixId"},{"column":"IPAddress","path":"$.ipAddress"},{"column":"FQDN","path":"$.fqdn"},{"column":"Zones","path":"$.zones"},{"column":"Tags","path":"$.tags"},{"column":"StatusDate","path":"$.statusDate"}]'

.create-or-alter table ResourceContainers ingestion json mapping 'ResourceContainers_mapping'
    '[{"column":"Timestamp","path":"$.timestamp"},{"column":"Cloud","path":"$.cloud"},{"column":"TenantId","path":"$.tenantId"},{"column":"SubscriptionId","path":"$.subscriptionId"},{"column":"Location","path":"$.location"},{"column":"ContainerType","path":"$.containerType"},{"column":"ContainerName","path":"$.containerName"},{"column":"InstanceId","path":"$.instanceId"},{"column":"ResourceCount","path":"$.resourceCount"},{"column":"ManagedBy","path":"$.managedBy"},{"column":"ContainerProperties","path":"$.containerProperties"},{"column":"Tags","path":"$.tags"},{"column":"StatusDate","path":"$.statusDate"}]'

.create-or-alter table SqlDatabases ingestion json mapping 'SqlDatabases_mapping'
