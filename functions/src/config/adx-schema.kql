// ============================================================================
// Stored functions for deduplicated views
// ============================================================================

// Deduplicated cost data: when CostData is re-ingested for the same usage date,
// only the most recently collected row per (UsageDate, InstanceId, MeterCategory,
// MeterSubCategory, MeterName) is kept.
.create-or-alter function LatestCostData() {
    CostData
    | summarize arg_max(Timestamp, *) by UsageDate, InstanceId, MeterCategory, MeterSubCategory, MeterName
}

// ============================================================================
// Materialized views for latest snapshot queries
// ============================================================================

.create-or-alter materialized-view LatestVMs on table VirtualMachines {
    VirtualMachines
    | summarize arg_max(Timestamp, *) by InstanceId
    }

.create-or-alter materialized-view LatestDisks on table ManagedDisks {
    ManagedDisks
    | summarize arg_max(Timestamp, *) by InstanceId
    }

.create-or-alter materialized-view LatestRecommendations on table Recommendations {
    Recommendations
    | summarize arg_max(GeneratedDate, *) by RecommendationId
    }

.create-or-alter materialized-view ActiveSuppressions on table Suppressions {
    Suppressions
    | summarize arg_max(FilterStartDate, *) by FilterId
    }
